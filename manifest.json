{
  "manifest_version": 3,
  "name": "GitHub PR Exporter",
  "version": "1.6.0",
  "description": "One-click export of GitHub PR pages to structured JSON.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://github.com/*"],
  "action": {
    "default_title": "Export PR to JSON",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
